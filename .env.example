# PostgreSQL (для n8n)
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me
POSTGRES_DB=n8n

# n8n
N8N_ENCRYPTION_KEY=change_me_32_chars_minimum
N8N_USER_MANAGEMENT_JWT_SECRET=change_me_jwt_secret

# LLM (Ollama модель, например llama3, mistral)
LLM=llama3

# API ключи (опционально для облачных LLM)
OPENAI_API_KEY=
MISTRAL_API_KEY=
GOOGLE_API_KEY=

# Embedding модель (ollama, openai, etc.)
EMBEDDING_MODEL=ollama

# LangChain (опционально)
LANGCHAIN_API_KEY=

# Telegram Bot
TOKEN=your_telegram_bot_token
CHANNEL_ID=your_channel_id
ADMIN_ID=your_telegram_user_id
